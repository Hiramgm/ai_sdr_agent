# Copy to .env and fill in. Never commit real secrets.

# LLM (open-source models via Groq free API)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Vector DB (Pinecone free account, hosted embeddings)
PINECONE_API_KEY=
PINECONE_INDEX=ai-sdr-leads
PINECONE_NAMESPACE=leads
PINECONE_TEXT_FIELD=text

# Databases
MONGODB_URI=mongodb://localhost:27017
POSTGRES_URL=postgresql://localhost:5432/ai_sdr

# Queue (Redis + RQ async workers)
REDIS_URL=redis://localhost:6379/0

# Observability (local by default; set sink to langfuse or phoenix to forward traces)
OBSERVABILITY_SINK=local
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
PHOENIX_ENDPOINT=
